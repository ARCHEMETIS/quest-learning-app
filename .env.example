# .env.example — ก๊อปเป็น .env แล้วเติมค่าจริง (สำหรับ netlify dev / vite dev)
# กฎเหล็ก: ห้ามตั้งชื่อ secret ขึ้นต้นด้วย VITE_ (Vite ฝัง VITE_* ลง bundle = รั่ว), .env จริงห้าม commit

# ── client (ฝังใน bundle ได้ ปลอดภัยเมื่อเปิด RLS) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── function เท่านั้น (ห้ามหลุดไป client) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-key
